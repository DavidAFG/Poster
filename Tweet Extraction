      "source": [
        "## EXTRAIRE JUSTE LES MESSAGES SANS LA DATE ##\n",
        "\n",
        "from selenium import webdriver\n",
        "from selenium.webdriver.chrome.service import Service\n",
        "from selenium.webdriver.chrome.options import Options\n",
        "from webdriver_manager.chrome import ChromeDriverManager\n",
        "from bs4 import BeautifulSoup\n",
        "import time\n",
        "\n",
        "# Configurer les options de Chrome\n",
        "chrome_options = Options()\n",
        "chrome_options.add_argument('--headless')  # Exécuter en arrière-plan\n",
        "chrome_options.add_argument('--no-sandbox')\n",
        "chrome_options.add_argument('--disable-dev-shm-usage')\n",
        "chrome_options.add_argument('user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/90.0.4430.212 Safari/537.36')\n",
        "\n",
        "url = 'https://rollcall.com/factbase/trump/topic/social/'\n",
        "\n",
        "# Lancer Chrome avec Selenium\n",
        "driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()), options=chrome_options)\n",
        "driver.get(url)\n",
        "\n",
        "# Attendre que la page charge et faire défiler pour charger plus de contenu\n",
        "time.sleep(5)\n",
        "for _ in range(3):\n",
        "    driver.execute_script(\"window.scrollTo(0, document.body.scrollHeight);\")\n",
        "    time.sleep(2)\n",
        "\n",
        "# Récupérer le HTML après chargement dynamique\n",
        "html = driver.page_source\n",
        "soup = BeautifulSoup(html, 'html.parser')\n",
        "\n",
        "# Trouver toutes les divs dont la classe commence par \"text-\"\n",
        "divs_with_text_class = soup.find_all('div', class_=lambda value: value and value.startswith('text-'))\n",
        "\n",
        "# Extraire le texte des balises <p> à l'intérieur de ces divs\n",
        "texts = []\n",
        "for div in divs_with_text_class:\n",
        "    p_tags = div.find_all('p')  # Trouver toutes les balises <p> dans la div\n",
        "    for p in p_tags:\n",
        "        text = p.get_text(strip=True)\n",
        "        if text:  # Si le texte n'est pas vide\n",
        "            texts.append(text)\n",
        "\n",
        "# Afficher les textes extraits\n",
        "print(f\"Nombre de textes extraits : {len(texts)}\")\n",
        "for i, text in enumerate(texts, 1):\n",
        "    print(f\"Texte {i}: {text}\\n\")\n",
        "\n",
        "# Fermer le navigateur\n",
        "driver.quit()"
      ],
